# Copy this file to .streamlit/secrets.toml and fill in your keys.
# On Streamlit Community Cloud, add these via the dashboard (Settings → Secrets).
# NEVER commit secrets.toml to git.

ANTHROPIC_API_KEY = "sk-ant-..."      # Claude AI scout reports
RAPIDAPI_KEY      = "your_key_here"   # Formation detection + transfer feed
LIVE_CACHE_TTL_HOURS      = "1"       # Transfer cache TTL in hours (default 1)
FORMATION_CACHE_TTL_HOURS = "2"       # Formation cache TTL in hours (default 2)
